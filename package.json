{
  "name": "bookmarktorain",
  "version": "1.0.0",
  "description": "Cloud Bookmarks Manager with plugin-based Raindrop sync",
  "main": "src/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:sqlite:migrate": "node scripts/sqlite-migrate.js",
    "db:sqlite:import-json": "node scripts/import-json-to-sqlite.js",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:release": "bash scripts/cf-release.sh",
    "cf:check": "node --check src/worker.js",
    "cf:smoke": "node scripts/cf-worker-smoke.mjs",
    "cf:d1:migrate:local": "bash scripts/cf-apply-d1-migration.sh local",
    "cf:d1:migrate:remote": "bash scripts/cf-apply-d1-migration.sh remote",
    "cf:d1:ensure": "node scripts/cf-ensure-d1-binding.mjs",
    "cf:d1:create": "node scripts/cf-ensure-d1-binding.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "bullmq": "^5.70.1",
    "express": "^5.2.1",
    "ioredis": "^5.9.3",
    "jsdom": "^28.1.0"
  },
  "devDependencies": {
    "wrangler": "^4.5.0"
  }
}
